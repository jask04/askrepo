# Copy to .env and fill in.

# Neon Postgres connection string. Use the pooled endpoint
# (hostname includes "-pooler") and keep ?sslmode=require.
DATABASE_URL=

# Google AI Studio API key. Used for Tour mode and as a fallback for
# local testing before the bring-your-own-key flow lands.
# https://aistudio.google.com -> Get API key
GOOGLE_API_KEY=

# Cookie encryption key for iron-session. Must be at least 32 chars.
# Generate one with: openssl rand -hex 32
SESSION_SECRET=

NODE_ENV=development
