# Copy to .env and fill in.

# Neon Postgres pooled connection string. Hostname includes "-pooler".
# Used by Prisma at runtime in serverless functions.
DATABASE_URL=

# Neon Postgres direct (non-pooled) connection. Same as DATABASE_URL
# with "-pooler" removed from the hostname. Used by Prisma for
# migrations, which don't work over the pooled endpoint.
DIRECT_DATABASE_URL=

# Google AI Studio API key. Used for Tour mode and as a fallback for
# local testing before the bring-your-own-key flow lands.
# https://aistudio.google.com -> Get API key
GOOGLE_API_KEY=

# Cookie encryption key for iron-session. Must be at least 32 chars.
# Generate one with: openssl rand -hex 32
SESSION_SECRET=

# Repo id powering the one-click tour. Optional — set this once a demo
# repo has been pre-indexed (see the Repo.id of an indexed repo). New
# deployments can use TOUR_REPO_URL alone; the app falls back to this URL
# if the stored id disappears after a reseed.
TOUR_REPO_ID=

# Repo URL used by demo maintenance to re-seed or refresh the tour index.
TOUR_REPO_URL=https://github.com/jask04/realtime-notifications

# Secret shared with Vercel Cron for /api/cron/demo. Generate with:
# openssl rand -hex 32
CRON_SECRET=

NODE_ENV=development
